# =============================================================================
# AiGeoPacific — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# SECRETS — NEVER COMMIT THESE
# -----------------------------------------------------------------------------
.env
.env.local
.env.production
.streamlit/secrets.toml

# -----------------------------------------------------------------------------
# CLIENT LOGOS — contain client data, never commit
# -----------------------------------------------------------------------------
assets/client_logos/*.png
assets/client_logos/*.jpg
assets/client_logos/*.jpeg

# -----------------------------------------------------------------------------
# LOCAL AUDIT HISTORY — user-specific data, not project code
# -----------------------------------------------------------------------------
~/.aigeopacific/
audit_history/
*.audit.json

# -----------------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
.installed.cfg
lib/
lib64/
MANIFEST

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
ENV/
env/
.env/
env.bak/
venv.bak/
.conda/
conda-env/

# -----------------------------------------------------------------------------
# IDEs
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Pytest / testing
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover
*.hypothesis/

# -----------------------------------------------------------------------------
# Jupyter
# -----------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# ReportLab / PDF temp files
# -----------------------------------------------------------------------------
*.pdf
temp_reports/

# -----------------------------------------------------------------------------
# Streamlit cache
# -----------------------------------------------------------------------------
.streamlit/cache/